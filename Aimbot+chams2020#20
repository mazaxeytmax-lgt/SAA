SmoothSlider.Position = UDim2.new(0.1, 0, 0.6, 0)
SmoothSlider.FocusLost:Connect(function()
    local val = tonumber(SmoothSlider.Text)
    if val then
        Smoothness = math.clamp(val, 0.01, 1)
