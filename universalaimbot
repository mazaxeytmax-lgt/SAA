SliderFrame.Position = UDim2.new(0.05, 0, 0.65, 0)
SliderFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)

local SliderLabel = Instance.new("TextLabel", SliderFrame)
SliderLabel.Size = UDim2.new(1, 0, 0, 20)
SliderLabel.Text = "SMOOTHNESS: " .. Config.Smoothness
SliderLabel.TextColor3 = Color3.new(1,1,1)
SliderLabel.BackgroundTransparency = 1

local SliderBtn = Instance.new("TextButton", SliderFrame)
SliderBtn.Size = UDim2.new(1, 0, 0.5, 0)
SliderBtn.Position = UDim2.new(0, 0, 0.5, 0)
SliderBtn.Text = "DESLIZA AQUÍ"
SliderBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)

SliderBtn.MouseButton1Down:Connect(function()
    local moveConn
    moveConn = RunService.RenderStepped:Connect(function()
        local mousePos = UserInputService:GetMouseLocation().X
        local relativePos = math.clamp((mousePos - SliderBtn.AbsolutePosition.X) / SliderBtn.AbsoluteSize.X, 0, 1)
        Config.Smoothness = math.round((relativePos * 0.9 + 0.1) * 100) / 100
        SliderLabel.Text = "SMOOTHNESS: " .. Config.Smoothness
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            moveConn:Disconnect()
        end
    end)
end)

